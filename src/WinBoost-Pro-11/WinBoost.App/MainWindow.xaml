<Window x:Class="WinBoost.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinBoost Pro 11"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->

        <Border Background="#2D2D30">

            <TextBlock
                Text="WinBoost Pro 11"
                Foreground="White"
                FontSize="28"
                FontWeight="Bold"
                VerticalAlignment="Center"
                Margin="20,0"/>

        </Border>

        <!-- CONTENT -->

        <Grid Grid.Row="1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- MENIU -->

            <StackPanel Background="#252526">

                <Button Content="Dashboard"
                        Margin="15"
                        Height="45"/>

                <Button Content="Performance"
                        Margin="15"
                        Height="45"/>

                <Button Content="Privacy"
                        Margin="15"
                        Height="45"/>

                <Button Content="Services"
                        Margin="15"
                        Height="45"/>

                <Button Content="Windows Update"
                        Margin="15"
                        Height="45"/>

                <Button Content="Apps"
                        Margin="15"
                        Height="45"/>

            </StackPanel>

            <!-- ZONA PRINCIPALĂ -->

            <Border Grid.Column="1"
                    Margin="20"
                    CornerRadius="8"
                    Background="#333333">

                <TextBlock
                    Text="Welcome to WinBoost Pro 11"
                    Foreground="White"
                    FontSize="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

            </Border>

        </Grid>

        <!-- STATUS BAR -->

        <Border Grid.Row="2"
                Background="#2D2D30">

            <TextBlock
                Text="Ready"
                Foreground="White"
                VerticalAlignment="Center"
                Margin="15,0"/>

        </Border>

    </Grid>

</Window>