<UserControl x:Class="WinBoost.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">

	<Grid Background="#1E1E1E">

		<TextBlock
            Text="Dashboard"
            FontSize="32"
            FontWeight="Bold"
            Foreground="White"
            Margin="30,20,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"/>

		<!-- CPU -->
		<Border
            Width="260"
            Height="120"
            Margin="30,90,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#2C2C2C"
            CornerRadius="12">

			<StackPanel Margin="15">

				<TextBlock
                    Text="CPU Usage"
                    FontSize="18"
                    Foreground="White"/>

				<TextBlock
                    Text="{Binding CpuUsage}"
                    FontSize="34"
                    FontWeight="Bold"
                    Foreground="{StaticResource AccentBrush}"
                    Margin="0,10,0,0"/>

			</StackPanel>

		</Border>

		<!-- RAM -->
		<Border
			Width="260"
			Height="145"
			Margin="320,90,0,0"
			HorizontalAlignment="Left"
			VerticalAlignment="Top"
			Background="#2C2C2C"
			CornerRadius="12">

			<StackPanel Margin="15">

				<TextBlock
					Text="RAM Usage"
					FontSize="18"
					Foreground="White"/>

				<TextBlock
					Text="{Binding RamUsage}"
					FontSize="38"
					FontWeight="Bold"
					Foreground="{StaticResource AccentBrush}"
					Margin="0,8,0,0"/>

				<TextBlock
					Text="{Binding RamDetails}"
					FontSize="20"
					FontWeight="SemiBold"
					Foreground="White"
					Opacity="0.85"
					Margin="0,6,0,0"/>

			</StackPanel>

		</Border>

		<!-- DISK -->
		<Border
            Width="260"
            Height="120"
            Margin="30,240,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#2C2C2C"
            CornerRadius="12">

			<StackPanel Margin="15">

				<TextBlock
                    Text="Disk Usage"
                    FontSize="18"
                    Foreground="White"/>

				<TextBlock
                    Text="{Binding DiskUsage}"
                    FontSize="34"
                    FontWeight="Bold"
                    Foreground="{StaticResource AccentBrush}"
                    Margin="0,10,0,0"/>

			</StackPanel>

		</Border>

		<!-- UPTIME -->
		<Border
            Width="260"
            Height="120"
            Margin="320,240,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#2C2C2C"
            CornerRadius="12">

			<StackPanel Margin="15">

				<TextBlock
                    Text="Windows Uptime"
                    FontSize="18"
                    Foreground="White"/>

				<TextBlock
                    Text="{Binding Uptime}"
                    FontSize="26"
                    FontWeight="Bold"
                    Foreground="{StaticResource AccentBrush}"
                    Margin="0,14,0,0"/>

			</StackPanel>

		</Border>

	</Grid>

</UserControl>